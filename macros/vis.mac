/run/initialize
/vis/open TSG 900x600-0+0
/vis/drawVolume

/vis/viewer/set/viewpointThetaPhi 80 20
/vis/viewer/set/targetPoint 0 0 0 cm
/vis/viewer/zoom 3.0

/vis/scene/add/axes 0 0 0 30 cm

/vis/scene/add/trajectories smooth
/vis/scene/endOfEventAction accumulate 5

/vis/viewer/set/autoRefresh true
/vis/verbose warnings

/run/beamOn 100